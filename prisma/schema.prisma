// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Listing {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // --- כותרת ותיאור ---
  title            String
  description      String?

  // --- מיקום ---
  city             String    @default("גבעת זאב")
  neighborhood     String?
  address          String?   /// כתובת מדויקת (רחוב + מספר)
  floor            Int?      /// קומה

  // --- מרחק ---
  /// קטגוריית מרחק לפי תקנון (לסינון ולסימולציה)
  walkDistance     WalkDistance

  // --- שינה ---
  rooms            Int       /// חדרים סגורים
  beds             Int       /// סה"כ מיטות
  bedsDouble       Int?      /// מיטות זוגיות
  bedsJewish       Int?      /// מיטות יהודיות (נפרדות)
  mattresses       Int?      /// מזרונים
  cribs            Int?      /// עריסות / לולים
  sofa             Boolean   @default(false) /// ספה נפתחת
  bedLinens        Boolean   @default(false) /// מצעים

  // --- ציוד ---
  ac               Boolean   @default(false) /// מזגן מרכזי
  shabbatPlate     Boolean   @default(false) /// פלטה לשבת
  shabbatUrnBoiler Boolean   @default(false) /// מיחם שבת
  shabbatClock     Boolean   @default(false) /// שעון שבת

  // --- שירותים ומרפסת ---
  bathrooms        Int?      /// מספר שירותים/חדרי רחצה
  balconyType      String?   /// מרפסת / גינה / חצר / אין
  balconySize      String?   /// גדולה / בינונית / קטנה

  // --- סלון ואוכל ---
  livingRoomSize   String?   /// גודל סלון: גדול / בינוני / קטן
  diningTable      String?   /// שולחן: מטבח / רגיל / אין
  chairs           String?   /// כסאות: סוג וכמות

  // --- מחיר ותמונה ---
  askingPriceNis   Int?
  imageUrl         String?

  // --- זמינות (שבועות תשפ"ו: 1-3 ביוני 2025) ---
  availableFrom    DateTime  @default(dbgenerated("'2025-06-01T00:00:00Z'::timestamp"))
  availableTo      DateTime  @default(dbgenerated("'2025-06-03T23:59:59Z'::timestamp"))

  // --- קשר ---
  contactPhone     String
  contactWhatsapp  String?

  published        Boolean  @default(true)
  isRented         Boolean  @default(false) /// סומן כמושכר
  /// מי פרסם (אימות Google)
  publisherEmail   String?

  interests        Interest[]
}

model Interest {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId   String
  email       String   /// מייל המתעניין
  name        String?  /// שם (אופציונלי)

  @@unique([listingId, email])
}

enum WalkDistance {
  upTo10
  upTo20
  over20
}
