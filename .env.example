# העתיקו ל-.env (או .env.local) ומלאו ערכים

# חובה ל־NextAuth (הפקה: openssl rand -base64 32)
AUTH_SECRET=

# כתובת האתר (מקומי / פרודקשן)
AUTH_URL=http://localhost:3000

# Google OAuth — מסוף הענן של גוגל → APIs & Services → Credentials → OAuth 2.0 Client
# Redirect URI בגוגל: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# PostgreSQL — מקומי: npm run db:up (Docker) או מחרוזת מ־Neon / Supabase לפרודקשן
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/dirotgz?schema=public"
